# ====================================================================
# XAUUSD Signal Alerter — environment configuration
# Copy this file to `.env` and fill in your values.
# ====================================================================

# --- Twelve Data ------------------------------------------------------
TWELVEDATA_API_KEY=paste_your_twelvedata_key_here

# Symbol on Twelve Data. Default is fine.
SYMBOL=XAU/USD

# Label used in email subjects/bodies (purely cosmetic).
SYMBOL_LABEL=XAUUSD

# --- Email (Gmail SMTP) ----------------------------------------------
# Use a Gmail App Password (NOT your regular Gmail password):
#   https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification on your Google account.
# 2. Generate a 16-character App Password for "Mail".
# 3. Paste it as SMTP_PASS below (no spaces).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
EMAIL_FROM=your_sender@gmail.com
EMAIL_TO=your_recipient@example.com

# --- Display ----------------------------------------------------------
# All bar timestamps in emails will be shown in UTC; signal/alert
# wall-clock timestamps are shown in this timezone.
DISPLAY_TIMEZONE=Asia/Kolkata

# --- Persistence ------------------------------------------------------
# Path to the state file. Default is fine — keep it inside the project dir.
STATE_FILE=state.json

# --- Future enhancement hook -----------------------------------------
# Restrict when entry alerts are sent. Empty = always send (default).
# Format: comma-separated HH:MM-HH:MM windows in DISPLAY_TIMEZONE local time.
# Example: ALERT_TIME_WINDOWS=14:00-15:00,18:00-19:00
# (Windows do NOT wrap midnight.)
ALERT_TIME_WINDOWS=
